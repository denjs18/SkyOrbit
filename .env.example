# ============================================
# VARIABLES D'ENVIRONNEMENT - VERCEL
# ============================================

# Copiez ce fichier en .env.local pour le développement local
# Sur Vercel, configurez ces variables dans le Dashboard

# ============================================
# BASE DE DONNÉES (Vercel Postgres ou externe)
# ============================================
DATABASE_URL="postgresql://user:password@host:5432/database"
# OU pour MySQL
# DATABASE_URL="mysql://user:password@host:3306/database"

DB_HOST="your-db-host.vercel-storage.com"
DB_PORT="5432"
DB_NAME="skyorbit_ulm"
DB_USER="your-db-user"
DB_PASSWORD="your-secure-password"

# ============================================
# API MÉTÉO
# ============================================

# OpenWeatherMap API (OBLIGATOIRE)
# Gratuit sur: https://openweathermap.org/api
OPENWEATHER_API_KEY="votre_cle_api_openweathermap"

# METAR/TAF API (Optionnel)
AVWX_API_KEY="votre_cle_api_avwx"

# ============================================
# COORDONNÉES GÉOGRAPHIQUES
# ============================================

# Coordonnées de votre aérodrome
LOCATION_LAT="43.5352"
LOCATION_LON="5.3672"
LOCATION_NAME="Aérodrome de Provence"
LOCATION_ICAO="LFML"
LOCATION_TIMEZONE="Europe/Paris"

# ============================================
# CONFIGURATION EMAIL (SMTP)
# ============================================

# Configuration SMTP pour envoi d'emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_ENCRYPTION="tls"
SMTP_USERNAME="votre-email@gmail.com"
SMTP_PASSWORD="votre-mot-de-passe-application"
SMTP_FROM_EMAIL="noreply@votre-club.fr"
SMTP_FROM_NAME="SkyOrbit ULM Club"

# ============================================
# INFORMATIONS DU CLUB
# ============================================

CLUB_NAME="Mon Club ULM"
CLUB_EMAIL="contact@mon-club-ulm.fr"
CLUB_PHONE="01 23 45 67 89"
CLUB_ADDRESS="Adresse de votre aérodrome"
CLUB_CITY="Marseille"
CLUB_POSTAL_CODE="13000"

# ============================================
# PAIEMENTS EN LIGNE (Optionnel)
# ============================================

# Stripe
STRIPE_PUBLIC_KEY="pk_test_XXXXXXXXXXXXXXXX"
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXX"

# PayPal
PAYPAL_CLIENT_ID="VOTRE_CLIENT_ID_PAYPAL"
PAYPAL_SECRET="VOTRE_SECRET_PAYPAL"
PAYPAL_MODE="sandbox"  # sandbox ou live

# ============================================
# SÉCURITÉ
# ============================================

# Clé secrète pour JWT/sessions (générez une chaîne aléatoire)
SECRET_KEY="votre-cle-secrete-tres-longue-et-aleatoire-32-caracteres-minimum"

# Salt pour hashage des mots de passe
PASSWORD_SALT="votre-salt-aleatoire"

# ============================================
# ENVIRONNEMENT
# ============================================

NODE_ENV="production"  # development, staging, production
APP_ENV="production"
APP_DEBUG="false"  # true en développement, false en production

# URL de base de l'application
APP_URL="https://votre-app.vercel.app"
BASE_URL="https://votre-app.vercel.app"

# ============================================
# CACHE & SESSIONS
# ============================================

# Redis (si vous utilisez Vercel KV)
REDIS_URL="redis://default:xxxxx@xxxxx.upstash.io:6379"
KV_URL="https://xxxxx.upstash.io"
KV_REST_API_URL="https://xxxxx.upstash.io"
KV_REST_API_TOKEN="xxxxx"
KV_REST_API_READ_ONLY_TOKEN="xxxxx"

# ============================================
# ANALYTICS (Optionnel)
# ============================================

GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
VERCEL_ANALYTICS_ID="xxxxx"

# ============================================
# STOCKAGE FICHIERS (Vercel Blob)
# ============================================

BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxx"

# ============================================
# AUTRES
# ============================================

# Limite de taille d'upload (en octets)
MAX_UPLOAD_SIZE="5242880"  # 5 MB

# Durée de session (en secondes)
SESSION_LIFETIME="3600"  # 1 heure

# Nombre max de tentatives de connexion
MAX_LOGIN_ATTEMPTS="5"

# Activer/désactiver les fonctionnalités
ENABLE_BAPTEMES="true"
ENABLE_PAYMENTS="false"
ENABLE_2FA="false"
ENABLE_NOTIFICATIONS="true"

# Mode maintenance
MAINTENANCE_MODE="false"
